---
import Layout from '../layouts/Layout.astro';
import LeadForm from '../components/LeadForm.astro';
import { locations } from '../data/locations';
import { normalizeUrl } from '../utils/urlHelper';

export async function getStaticPaths() {
  return locations.flatMap(location => 
    location.communes.map(commune => ({
      params: { 
        commune: normalizeUrl(commune)
      },
      props: { 
        provinceName: location.province,
        communeName: commune
      }
    }))
  );
}

const { commune } = Astro.params;
const { provinceName, communeName } = Astro.props;

const displayCommune = communeName.replace(/-/g, ' ');
const capitalizedCommune = displayCommune.split(' ')
  .map(word => word.charAt(0).toUpperCase() + word.slice(1))
  .join(' ');

const title = `Plombier à ${capitalizedCommune} | Service 24/7`;
const description = `Service de plomberie professionnel à ${capitalizedCommune}. Intervention rapide 24/7, dépannage d'urgence, installation et réparation. Devis gratuit ☎ 0472/80.80.80`;
---

<Layout title={title} description={description}>
  <section class="relative bg-gradient-to-br from-blue-900 via-blue-800 to-blue-600 text-white py-20">
    <div class="absolute inset-0 bg-[url('/grid.svg')] opacity-10"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-blue-900/50 to-transparent"></div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div>
          <span class="inline-block px-4 py-1 rounded-full bg-blue-500/20 backdrop-blur-sm text-white mb-4">
            Disponible 24/7 à {capitalizedCommune}
          </span>
          <h1 class="text-4xl md:text-5xl font-bold mb-6 leading-tight">
            Plombier à {capitalizedCommune}
          </h1>
          <p class="text-xl mb-8 text-blue-100">
            Service de plomberie professionnel à {capitalizedCommune}. Intervention rapide garantie.
          </p>
          <div class="flex flex-wrap gap-4">
            <a href="tel:0472808080" class="bg-white text-blue-600 px-6 py-3 rounded-xl font-bold hover:bg-blue-50 transition duration-300 shadow-lg hover:shadow-xl flex items-center gap-2">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
              Appeler maintenant
            </a>
            <a href="#devis" class="border-2 border-white/30 backdrop-blur-sm text-white px-6 py-3 rounded-xl font-bold hover:bg-white/10 transition duration-300 flex items-center gap-2">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
              </svg>
              Devis gratuit
            </a>
          </div>
        </div>
        <div class="relative">
          <div class="absolute inset-0 bg-gradient-to-r from-blue-600/30 to-purple-600/30 rounded-2xl blur-3xl"></div>
          <div class="relative" id="devis">
            <LeadForm />
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-2 gap-12">
        <div class="prose max-w-none">
          <h2 class="text-3xl font-bold mb-6">Service de Plomberie Professionnel à {capitalizedCommune}</h2>
          <p class="text-lg mb-4">
            Notre équipe de plombiers professionnels est fière d'offrir ses services aux résidents de {capitalizedCommune}. 
            Avec plus de 15 ans d'expérience dans le domaine, nous comprenons les défis spécifiques liés à la plomberie 
            dans votre région et nous nous engageons à fournir des solutions rapides et durables.
          </p>
          
          <h3 class="text-2xl font-bold mt-8 mb-4">Notre Expertise à {capitalizedCommune}</h3>
          <p>
            Nous intervenons sur tous types de problèmes de plomberie, des plus simples aux plus complexes. Notre équipe 
            est formée aux dernières technologies et techniques de plomberie, garantissant ainsi un service de qualité 
            supérieure pour chaque intervention.
          </p>

          <div class="bg-blue-50 p-6 rounded-lg my-8">
            <h4 class="text-xl font-bold mb-4">Nos Services Incluent :</h4>
            <ul class="space-y-2">
              <li class="flex items-center gap-2">
                <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                Dépannage d'urgence 24/7
              </li>
              <li class="flex items-center gap-2">
                <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                Installation et rénovation de plomberie
              </li>
              <li class="flex items-center gap-2">
                <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                Détection et réparation de fuites
              </li>
              <li class="flex items-center gap-2">
                <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                Débouchage de canalisations
              </li>
              <li class="flex items-center gap-2">
                <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                Installation de chauffe-eau
              </li>
            </ul>
          </div>

          <h3 class="text-2xl font-bold mt-8 mb-4">Pourquoi Choisir Notre Service à {capitalizedCommune} ?</h3>
          <ul class="space-y-4">
            <li class="flex items-start gap-3">
              <svg class="w-6 h-6 text-blue-600 flex-shrink-0 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <div>
                <span class="font-semibold">Intervention Rapide</span>
                <p class="text-gray-600">Nous intervenons dans les 30 minutes pour les urgences à {capitalizedCommune}.</p>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-6 h-6 text-blue-600 flex-shrink-0 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
              <div>
                <span class="font-semibold">Garantie Qualité</span>
                <p class="text-gray-600">Tous nos travaux sont garantis pour votre tranquillité d'esprit.</p>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-6 h-6 text-blue-600 flex-shrink-0 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z" />
              </svg>
              <div>
                <span class="font-semibold">Transparence Totale</span>
                <p class="text-gray-600">Devis détaillé gratuit avant chaque intervention.</p>
              </div>
            </li>
          </ul>
        </div>

        <div class="space-y-8">
          <div class="bg-white p-6 rounded-xl shadow-lg">
            <h3 class="text-xl font-bold mb-4">Zone d'Intervention à {capitalizedCommune}</h3>
            <p class="text-gray-600 mb-4">
              Notre équipe de plombiers intervient dans tous les quartiers de {capitalizedCommune} et ses environs. 
              Notre proximité nous permet de garantir des délais d'intervention rapides, essentiels en cas d'urgence.
            </p>
            <div class="mt-4">
              <h4 class="font-semibold mb-2">Nous Intervenons Pour :</h4>
              <ul class="space-y-2 text-gray-600">
                <li>• Particuliers</li>
                <li>• Professionnels</li>
                <li>• Copropriétés</li>
                <li>• Institutions</li>
              </ul>
            </div>
          </div>

          <div class="bg-white p-6 rounded-xl shadow-lg">
            <h3 class="text-xl font-bold mb-4">Conseils d'Entretien</h3>
            <div class="space-y-4">
              <div>
                <h4 class="font-semibold mb-2">Prévention des Fuites</h4>
                <p class="text-gray-600">
                  Inspectez régulièrement vos installations pour détecter les signes avant-coureurs de fuites :
                  taches d'humidité, baisse de pression, bruits inhabituels.
                </p>
              </div>
              <div>
                <h4 class="font-semibold mb-2">Entretien des Canalisations</h4>
                <p class="text-gray-600">
                  Un entretien régulier permet d'éviter les bouchons et les mauvaises odeurs. Utilisez des produits
                  adaptés et évitez de jeter des déchets dans les éviers.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold mb-12 text-center">Nos Services de Plomberie à {capitalizedCommune}</h2>
      <div class="grid md:grid-cols-3 gap-8">
        <div class="bg-white p-6 rounded-xl shadow-lg">
          <div class="w-12 h-12 bg-blue-600 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-4">Dépannage d'Urgence</h3>
          <ul class="space-y-2 text-gray-600">
            <li>• Fuites d'eau</li>
            <li>• WC bouchés</li>
            <li>• Problèmes de chauffe-eau</li>
            <li>• Canalisations bouchées</li>
          </ul>
        </div>

        <div class="bg-white p-6 rounded-xl shadow-lg">
          <div class="w-12 h-12 bg-blue-600 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-4">Installation</h3>
          <ul class="space-y-2 text-gray-600">
            <li>• Sanitaires</li>
            <li>• Chauffe-eau</li>
            <li>• Robinetterie</li>
            <li>• Systèmes d'évacuation</li>
          </ul>
        </div>

        <div class="bg-white p-6 rounded-xl shadow-lg">
          <div class="w-12 h-12 bg-blue-600 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-4">Détection de Fuites</h3>
          <ul class="space-y-2 text-gray-600">
            <li>• Détection acoustique</li>
            <li>• Caméra thermique</li>
            <li>• Inspection vidéo</li>
            <li>• Réparation immédiate</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-gradient-to-br from-blue-900 to-blue-800 rounded-3xl overflow-hidden">
        <div class="px-8 py-12 md:p-16">
          <div class="max-w-3xl">
            <h2 class="text-3xl md:text-4xl font-bold text-white mb-6">
              Besoin d'un plombier à {capitalizedCommune} ?
            </h2>
            <p class="text-blue-100 text-lg mb-8">
              Notre équipe de professionnels est disponible 24/7 pour tous vos besoins en plomberie.
              Contactez-nous pour un devis gratuit !
            </p>
            <div class="flex flex-wrap gap-4">
              <a href="tel:0472808080" class="bg-white text-blue-600 px-8 py-4 rounded-xl font-bold hover:bg-blue-50 transition duration-300">
                Appeler maintenant
              </a>
              <a href="#devis" class="bg-blue-700 text-white px-8 py-4 rounded-xl font-bold hover:bg-blue-600 transition duration-300">
                Demander un devis
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>